});
});

// Slash command kezelés
client.on('interactionCreate', async (interaction) => {

// /partneradd slash command
if (interaction.isChatInputCommand() && interaction.commandName === 'partneradd') {
const modal = new ModalBuilder()
.setCustomId('partnerModal')
.setTitle('Partnerhirdetés beküldése');

const discordIdInput = new TextInputBuilder()
.setCustomId('discordIdInput')
.setLabel('Partner Discord ID')
.setStyle(TextInputStyle.Short)
.setMinLength(18)
.setMaxLength(18)
.setRequired(true);

const pingInput = new TextInputBuilder()
.setCustomId('pingInput')
.setLabel('Ping típusa - nem kötelező')
.setStyle(TextInputStyle.Short)
.setMinLength(1)
.setMaxLength(10)
.setRequired(false);

const contentInput = new TextInputBuilder()
.setCustomId('contentInput')
.setLabel('Partner szöveg')
.setStyle(TextInputStyle.Paragraph)
.setMinLength(1)
.setMaxLength(2000)
.setRequired(true);

modal.addComponents(
new ActionRowBuilder().addComponents(discordIdInput),
new ActionRowBuilder().addComponents(pingInput),
new ActionRowBuilder().addComponents(contentInput)
);

await interaction.showModal(modal);
}

// partnerModal beküldés
if (interaction.type === InteractionType.ModalSubmit && interaction.customId === 'partnerModal') {
const discordId = interaction.fields.getTextInputValue('discordIdInput');
const ping = interaction.fields.getTextInputValue('pingInput');
const content = interaction.fields.getTextInputValue('contentInput');

// Ellenőrzés: csak szám lehet az ID
if (isNaN(discordId)) {
await interaction.reply({ content: '❌ Csak számot adj meg Discord ID-ként!', ephemeral: true });
return;
}

await interaction.reply({ content: '📨 Beküldve!', ephemeral: true });

const csatorna = await client.channels.fetch(PARTNER_KERELMEK_CSATORNA);

// Először küldjük el a partner szöveget
const partnerSzovegUzenet = await csatorna.send(content);

// Majd az admin üzenetet gombokkal
const gombsor = new ActionRowBuilder().addComponents(
new ButtonBuilder()
.setCustomId(accept_partner-${partnerSzovegUzenet.id}`)
.setLabel('Jóváhagyás')
.setStyle(ButtonStyle.Success)
.setEmoji('✅'),
new ButtonBuilder()
.setCustomId('edit_partner')
.setLabel('Szerkesztés')
.setStyle(ButtonStyle.Primary)
.setEmoji('✏️'),
new ButtonBuilder()
.setCustomId('deny_partner')
.setLabel('Elutasítás')
.setStyle(ButtonStyle.Danger)
.setEmoji('❎')
);

await csatorna.send({
content: 📋 **ÚJ PARTNERKÉRELEM**\n**Beküldő:** &lt;@${interaction.user.id}>\nID:${discordId}\n**Ping:** ${ping}`,
components: [gombsor]
});
}

// Gombok kezelése
if (interaction.isButton()) {

// Jóváhagyás gomb
if (interaction.customId.startsWith('accept_partner-')) {
const uzenetId = interaction.customId.replace('accept_partner-', '');

await interaction.update({ content: '✅ Jóváhagyva!', components: [] });

const kerelmekCsatorna = await client.channels.fetch(PARTNER_KERELMEK_CSATORNA);
const partnerSzovegUzenet = await kerelmekCsatorna.messages.fetch(uzenetId);

const partnereinkCsatorna = await client.channels.fetch(PARTNEREINK_CSATORNA);
await partnereinkCsatorna.send(partnerSzovegUzenet.content);
}

// Elutasítás gomb
if (interaction.customId === 'deny_partner') {
await interaction.update({ content: '❌ Elutasítva!', components: [] });
}

// Szerkesztés gomb
if (interaction.customId === 'edit_partner') {
const modal = new ModalBuilder()
.setCustomId('partnerEditModal')
.setTitle('Partnerhirdetés szerkesztése');

const newDiscordIdInput = new TextInputBuilder()
.setCustomId('newDiscordIdInput')
.setLabel('Partner Discord ID')
.setStyle(TextInputStyle.Short)
.setMinLength(18)
.setMaxLength(18)
.setRequired(true);

const newPingInput = new TextInputBuilder()
.setCustomId('newPingInput')
.setLabel('Ping típusa - nem kötelező')
.setStyle(TextInputStyle.Short)
.setMinLength(1)
.setMaxLength(10)
.setRequired(false);

const newContentInput = new TextInputBuilder()
.setCustomId('newContentInput')
.setLabel('Új szöveg')
.setStyle(TextInputStyle.Paragraph)
.setMinLength(1)
.setMaxLength(2000)
.setRequired(true);

modal.addComponents(
new ActionRowBuilder().addComponents(newDiscordIdInput),
new ActionRowBuilder().addComponents(newPingInput),
new ActionRowBuilder().addComponents(newContentInput)
);

await interaction.showModal(modal);
}
}

// partnerEditModal beküldés
if (interaction.type === InteractionType.ModalSubmit && interaction.customId === 'partnerEditModal') {
const newDiscordId = interaction.fields.getTextInputValue('newDiscordIdInput');
const newPing = interaction.fields.getTextInputValue('newPingInput');
const newContent = interaction.fields.getTextInputValue('newContentInput');

if (isNaN(newDiscordId)) {
await interaction.reply({ content: '❌ Csak számot adj meg Discord ID-ként!', ephemeral: true });
return;
}

await interaction.update({ content: '✏️ Szerkesztve!', components: [] });

const csatorna = await client.channels.fetch(PARTNER_KERELMEK_CSATORNA);

const partnerSzovegUzenet = await csatorna.send(newContent);

const gombsor = new ActionRowBuilder().addComponents(
new ButtonBuilder()
.setCustomId(accept_partner-${partnerSzovegUzenet.id}`)
.setLabel('Jóváhagyás')
.setStyle(ButtonStyle.Success)
.setEmoji('✅'),
new ButtonBuilder()
.setCustomId('edit_partner')
.setLabel('Szerkesztés')
.setStyle(ButtonStyle.Primary)
.setEmoji('✏️'),
new ButtonBuilder()
.setCustomId('deny_partner')
.setLabel('Elutasítás')
.setStyle(ButtonStyle.Danger)
.setEmoji('❎')
);

await csatorna.send({
content: ✏️ **SZERKESZTETT VERZIÓ**\n**ID:** ${newDiscordId}\nPing:${newPing}\n**Beküldött szöveg:**\n${newContent},
components: [gombsor]
});
}
});

client.login(TOKEN);
