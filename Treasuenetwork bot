const { Client, GatewayIntentBits, ModalBuilder, TextInputBuilder, TextInputStyle, ActionRowBuilder, ButtonBuilder, ButtonStyle, InteractionType } = require('discord.js');

const client = new Client({
intents: [
GatewayIntentBits.Guilds,
GatewayIntentBits.GuildMembers,
GatewayIntentBits.GuildMessages,
 ]
});

// Csatorna ID-k
const PARTNER_KERELMEK_CSATORNA = '1516909207520149675';
const PARTNEREINK_CSATORNA = '1501207636522041415';
const UDVOZLO_CSATORNA = '1500894375792742400';

// Bot token - ezt cseréld ki a saját tokeneire!
const TOKEN = 'MTUxNjg3MDk4OTc4NTQ2ODkzOQ.G8hMzW.fWELgHEmzNETivA9YbMP3Ot8NZ4dbU0sVsZEek
';

client.once('ready', () => {
console.log(Bot bejelentkezve: ${client.user.tag}`);
});

// Üdvözlő üzenet amikor valaki csatlakozik
client.on('guildMemberAdd', async (member) => {
const csatorna = await client.channels.fetch(UDVOZLO_CSATORNA);
if (!csatorna) return;

await csatorna.send({
content: Üdvözlünk &lt;@${member.id}>, érezd jól magad a ✦ 𝓣𝓻𝓮𝓪𝓼𝓾𝓻𝓮𝓝𝓮𝓽𝔀𝓸𝓻𝓴 ✦ szerverén! 🙌 Te vagy a **${member.guild.memberCount}.** tagunk.,
